YIMAI_ENV=prod
YIMAI_DATABASE_URL=postgresql+asyncpg://REPLACE_ME
YIMAI_REDIS_URL=rediss://REPLACE_ME
YIMAI_COORDINATION_BACKEND=redis
YIMAI_JWT_SECRET=REPLACE_ME
YIMAI_SECRET_BACKEND=vault
YIMAI_VAULT_ADDR=https://vault.example.internal:8200
YIMAI_VAULT_TOKEN=REPLACE_ME
YIMAI_CORS_ORIGINS=["https://axon.example.com"]
YIMAI_WEBHOOK_SECRETS={"ci-prod":"REPLACE_ME"}
YIMAI_SEED_ADMIN_USER=axon-admin
YIMAI_SEED_ADMIN_PASSWORD=REPLACE_ME
# gRPC Agent 监听端口由 API 进程持有；启用 Agent 时必须保持单 worker。
AXON_API_WORKERS=1
AXON_CELERY_CONCURRENCY=4

# Agent mTLS（启用时取消注释；50051/TCP 由主机防火墙只对纳管网段开放）
# YIMAI_AGENT_GRPC_ENABLED=true
# YIMAI_AGENT_GRPC_TLS_ENABLED=true
# YIMAI_AGENT_GRPC_SERVER_CERT_FILE=/etc/axon/tls/agent-grpc.crt
# YIMAI_AGENT_GRPC_SERVER_KEY_FILE=/etc/axon/tls/agent-grpc.key
# YIMAI_AGENT_GRPC_CLIENT_CA_FILE=/etc/axon/tls/agent-client-ca.crt
# YIMAI_AGENT_GRPC_SERVER_ADDRESS=agent-grpc.example.com:50051
