{
  "components": {
    "schemas": {
      "AccessMode": {
        "enum": [
          "ssh",
          "agent"
        ],
        "title": "AccessMode",
        "type": "string"
      },
      "DeployRequestBody": {
        "description": "UI 触发部署入参(§15.2 body:{version, strategy})。env 取自服务本身,不由前端传。",
        "properties": {
          "git_sha": {
            "anyOf": [
              {
                "maxLength": 64,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Git Sha"
          },
          "strategy": {
            "$ref": "#/components/schemas/DeploymentStrategy",
            "default": "rolling"
          },
          "version": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "version"
        ],
        "title": "DeployRequestBody",
        "type": "object"
      },
      "DeploymentStrategy": {
        "enum": [
          "rolling",
          "canary",
          "blue-green",
          "recreate"
        ],
        "title": "DeploymentStrategy",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "password": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Username",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "ReloadMode": {
        "enum": [
          "reload",
          "restart"
        ],
        "title": "ReloadMode",
        "type": "string"
      },
      "Runtime": {
        "enum": [
          "k8s",
          "docker",
          "systemd",
          "process",
          "cloud-fn"
        ],
        "title": "Runtime",
        "type": "string"
      },
      "ServerRegisterRequest": {
        "description": "纳管 API 入参(§3.2)。\n\n与 ServerCreate 的区别:SSH 模式收**私钥明文**（ssh_private_key）而非\ncredential_id——私钥由 API 层存入保险箱换取 credential_id，绝不落业务表（§13）。",
        "properties": {
          "access_mode": {
            "$ref": "#/components/schemas/AccessMode"
          },
          "agent_id": {
            "anyOf": [
              {
                "maxLength": 128,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Agent Id"
          },
          "host": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Host",
            "type": "string"
          },
          "labels": {
            "additionalProperties": true,
            "title": "Labels",
            "type": "object"
          },
          "name": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "ssh_port": {
            "default": 22,
            "maximum": 65535.0,
            "minimum": 1.0,
            "title": "Ssh Port",
            "type": "integer"
          },
          "ssh_private_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ssh Private Key"
          },
          "username": {
            "anyOf": [
              {
                "maxLength": 64,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          }
        },
        "required": [
          "name",
          "host",
          "access_mode"
        ],
        "title": "ServerRegisterRequest",
        "type": "object"
      },
      "ServiceCreate": {
        "properties": {
          "desired_version": {
            "anyOf": [
              {
                "maxLength": 128,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Desired Version"
          },
          "env": {
            "$ref": "#/components/schemas/ServiceEnvironment"
          },
          "health_check": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Health Check"
          },
          "name": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "reload_mode": {
            "$ref": "#/components/schemas/ReloadMode",
            "default": "restart"
          },
          "runtime": {
            "$ref": "#/components/schemas/Runtime"
          },
          "runtime_ref": {
            "additionalProperties": true,
            "minProperties": 1,
            "title": "Runtime Ref",
            "type": "object"
          }
        },
        "required": [
          "name",
          "env",
          "runtime",
          "runtime_ref"
        ],
        "title": "ServiceCreate",
        "type": "object"
      },
      "ServiceEnvironment": {
        "enum": [
          "dev",
          "staging",
          "prod"
        ],
        "title": "ServiceEnvironment",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
