# 一脉 Axon 统一运维控制面 —— 环境变量示例
# 复制为 .env 后按需修改。.env 已被 .gitignore 忽略,勿提交真实密钥。
# 后端全部配置项前缀为 YIMAI_(见 backend/app/core/config.py)。

# ============ docker-compose 编排用(compose 直接读取,无 YIMAI_ 前缀)============
# postgres 账号/库名/端口(compose 内 postgres 服务与后端连接串共用)
POSTGRES_USER=yimai
POSTGRES_PASSWORD=yimai
POSTGRES_DB=yimai
POSTGRES_PORT=5432
REDIS_PORT=6379
# 各服务对外暴露端口(改这里即可避开本机端口冲突)
API_PORT=8000
FRONTEND_PORT=5173
FLOWER_PORT=5555
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============ 后端应用配置(YIMAI_ 前缀,api/worker/beat 容器读取)============
# 运行环境:dev | staging | prod
YIMAI_ENV=dev
YIMAI_DEBUG=false

# --- 数据库 ---
# 默认 PostgreSQL(生产)。切库见 docs/使用与部署.md「切换数据库」章节。
#   PostgreSQL: postgresql+asyncpg://用户:密码@主机:5432/库名
#   SQLite(本地/试用): sqlite+aiosqlite:///./axon.db
#   MySQL(需自行加驱动 aiomysql): mysql+aiomysql://用户:密码@主机:3306/库名
YIMAI_DATABASE_URL=postgresql+asyncpg://yimai:yimai@localhost:5432/yimai
YIMAI_DB_ECHO=false

# --- 认证(JWT)---
# 生产务必换成 32 字节以上随机串(如 openssl rand -hex 32),勿用默认值。
YIMAI_JWT_SECRET=CHANGE-ME-32-bytes-min-in-production
YIMAI_JWT_EXPIRES_MINUTES=480

# --- 凭证保险箱(§13):local(Fernet)| vault ---
# 生产必须使用 vault；local 仅用于 dev/staging，当前 local 凭证只存在进程内。
YIMAI_SECRET_BACKEND=local
# local 后端主密钥:生产由 KMS 注入,勿写进文件。留空时启动会用临时密钥(重启即失效)。
YIMAI_SECRET_MASTER_KEY=
# vault 后端才需要:
# YIMAI_VAULT_ADDR=http://vault:8200
# YIMAI_VAULT_TOKEN=

# --- 任务队列(Celery + Redis)---
YIMAI_REDIS_URL=redis://localhost:6379/0
# memory 仅开发/测试；生产启动校验要求 redis。
YIMAI_COORDINATION_BACKEND=memory
YIMAI_DEPLOY_RECONCILE_LEASE_TTL_SEC=180

# --- Prometheus 查询代理(§15.4)---
YIMAI_PROMETHEUS_BASE_URL=http://localhost:9090

# --- 高级发布 provider(可选)---
# Kubernetes canary/blue-green 通过 Argo Rollouts CustomObjects API。
YIMAI_ARGO_ROLLOUTS_ENABLED=false
YIMAI_ARGO_ROLLOUTS_HEALTH_TIMEOUT_SEC=300
# 裸机/Docker canary/blue-green 通过企业 LB adapter HTTP API。
# YIMAI_LOAD_BALANCER_CONFIG={"provider":"http","base_url":"https://lb-adapter.internal","token_credential_id":"...","timeout_sec":"10"}

# --- 种子管理员(首次 seed 用,见部署文档)---
YIMAI_SEED_ADMIN_USER=admin
YIMAI_SEED_ADMIN_PASSWORD=admin

# --- 入向 webhook 每源 HMAC secret(§8.3)---
# JSON:键为 X-Webhook-Source 头值,值为该源 secret(轮转期可逗号分隔双 secret)。
# 缺省为空 = 拒绝所有 webhook。示例:
# YIMAI_WEBHOOK_SECRETS={"gitlab-prod":"secret1","sonarqube":"secret2"}

# --- Agent gRPC(可选,生产必须 mTLS)---
# 默认关闭。开发/测试启用时可显式设 false 使用 insecure；生产启用 Agent 必须 true。
YIMAI_AGENT_GRPC_ENABLED=false
YIMAI_AGENT_GRPC_HOST=0.0.0.0
YIMAI_AGENT_GRPC_PORT=50051
YIMAI_AGENT_GRPC_TLS_ENABLED=false
# 安装脚本使用的控制面地址；生产启用 Agent 时必须填写可解析地址。
# YIMAI_AGENT_GRPC_SERVER_ADDRESS=control-plane.internal:50051
# 目标机证书文件路径（由配置管理预置）
YIMAI_AGENT_GRPC_CLIENT_CA_PATH=/etc/axon/tls/ca.crt
YIMAI_AGENT_GRPC_CLIENT_CERT_PATH=/etc/axon/tls/agent.crt
YIMAI_AGENT_GRPC_CLIENT_KEY_PATH=/etc/axon/tls/agent.key
# YIMAI_AGENT_GRPC_CLIENT_SERVER_NAME=agent-grpc.internal
# 开发环境显式允许安装脚本使用明文；生产校验拒绝 true。
YIMAI_AGENT_INSECURE_INSTALL=false
YIMAI_AGENT_CONFIG_ROOTS=["/etc/axon"]
YIMAI_AGENT_ARTIFACT_STAGING_DIR=/tmp/axon-artifacts
# 生产通过 secret volume 注入以下 PEM 文件，不要把私钥提交到仓库。
# YIMAI_AGENT_GRPC_SERVER_CERT_FILE=/run/secrets/agent-grpc/server.crt
# YIMAI_AGENT_GRPC_SERVER_KEY_FILE=/run/secrets/agent-grpc/server.key
# YIMAI_AGENT_GRPC_CLIENT_CA_FILE=/run/secrets/agent-grpc/client-ca.crt
# 紧急吊销列表(JSON 数组)，身份取客户端证书 SAN/CN 且必须等于 agent_id。
# YIMAI_AGENT_GRPC_REVOKED_AGENT_IDS=["node-01"]
YIMAI_AGENT_ARTIFACT_CHUNK_BYTES=196608
YIMAI_AGENT_ARTIFACT_MAX_BYTES=1073741824

# --- 部署门禁与自动回滚(默认安全:拦 critical、不自动回滚)---
YIMAI_DEPLOY_BLOCK_ON_CRITICAL=true
YIMAI_AUTO_ROLLBACK_ON_ALERT=false
